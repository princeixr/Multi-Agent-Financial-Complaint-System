# Copy to .env and adjust values. LangChain reads OPENAI_API_KEY from the environment.

# PostgreSQL (must include pgvector). Default matches docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/complaints

# OpenAI — required for all chat agents (classification, risk, resolution, etc.)
OPENAI_API_KEY=sk-REPLACE_ME_WITH_YOUR_KEY

# Embeddings: huggingface (free, local) or openai (paid API)
EMBEDDING_PROVIDER=huggingface
# HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# HF_DEVICE=cpu
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional
# LOG_LEVEL=INFO
# SQL_ECHO=
