# Copy to .env and adjust values. LangChain reads OPENAI_API_KEY from the environment.

# PostgreSQL (must include pgvector). Default matches docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/complaints

# ── LLM Provider ────────────────────────────────────────────────────────────
# Supported: "openai" (default) or "deepseek"
LLM_PROVIDER=openai
# LLM_PROVIDER=deepseek

# ── OpenAI ──────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o

# ── DeepSeek ────────────────────────────────────────────────────────────────
# Uncomment and set LLM_PROVIDER=deepseek to use DeepSeek instead of OpenAI.
# DEEPSEEK_API_KEY=
# DEEPSEEK_CHAT_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Embeddings: huggingface (free, local) or openai (paid API)
EMBEDDING_PROVIDER=huggingface
# HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# HF_DEVICE=cpu
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional
# LOG_LEVEL=INFO
# SQL_ECHO=
# PG_CONNECT_TIMEOUT=5
# DISABLE_VECTOR_DB=1   # run agents without Postgres/pgvector RAG (local scripts)
# FORCE_VECTOR_DB=1     # always use RAG; fail if DB is down

# LangSmith (LangChain / LangGraph runs in https://smith.langchain.com )
# Not related to app/observability/tracing.py (OpenTelemetry), which only logs locally
# unless you add an OTLP exporter yourself.
#
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_REPLACE_ME
# LANGCHAIN_PROJECT=complaint-agent
#
# Newer SDKs may also accept:
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=complaint-agent

# Intake privacy: by default, do NOT send raw intake chat turns to LangSmith.
# Downstream workflow tracing (Supervisor + specialists) can still be enabled via LANGCHAIN_TRACING_V2.
# TRACE_INTAKE_TO_LANGSMITH=1

# OpenTelemetry (trace_id + optional console export)
# OTEL_SERVICE_NAME=complaint-classification-agent
# WORKFLOW_VERSION=1.0.0
# PROMPT_BUNDLE_VERSION=default
# OTEL_TRACES_CONSOLE=true   # print spans to stdout (dev only)
# TRACE_NARRATIVE_MAX_CHARS=240

# testing_sample.py: how many valid CSV rows to run (default 10)
# TEST_SAMPLE_COUNT=10

# ── ElevenLabs (Conversational AI Custom LLM + optional TTS) ────────────────
# Custom LLM base URL in the ElevenLabs agent settings should be:
#   https://<your-public-host>/api/v1/integrations/elevenlabs
# (requests go to .../v1/chat/completions as SSE).
#
# ELEVENLABS_API_KEY=
# Optional: protect Custom LLM + /tts with Bearer token (set the same secret in ElevenLabs).
# ELEVENLABS_CUSTOM_LLM_SECRET=
# Optional: fail if user/user_id is missing (recommended for production multi-turn).
# ELEVENLABS_INTAKE_REQUIRE_USER=1
# Required for spoken replies in the lodge UI + /api/v1/intake/tts (also: VOICE_ID, ELEVENLABS_VOICE).
# ELEVENLABS_VOICE_ID=

# ── Jira Integration (Team TriageAI) ───────────────────────────────────
# When JIRA_API_TOKEN is set, the routing agent will automatically create a
# Jira Task in the configured project for every routed complaint.
# Generate your token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_BASE_URL=https://<your-site>.atlassian.net
# JIRA_USER_EMAIL=<your-email>
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=KAN
# JIRA_ASSIGNEE_ID=<account-id>

ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""